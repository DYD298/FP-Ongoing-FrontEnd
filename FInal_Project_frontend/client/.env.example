# Guest read credential for /ads/active (choose one)
# Option 1: OAuth2 Bearer token (subscription/app token with read access)
VITE_PUBLIC_READ_BEARER_TOKEN=

# Option 2: API Key (if the API is configured to allow API key auth)
VITE_PUBLIC_READ_API_KEY=

# Optional public image base URL for guest image loading
# If you use /ads as base, app will normalize it to /ads/image internally.
VITE_PUBLIC_ADS_IMAGE_BASE_URL=http://100.72.161.91:32104/ads

# Optional override API base URLs for admin dashboards
VITE_ADMIN_API_BASE_URL=
VITE_SUPER_ADMIN_API_BASE_URL=
